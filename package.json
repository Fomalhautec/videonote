{
  "name": "videonote",
  "private": true,
  "version": "1.0.2",
  "description": "VideoNote - A note-taking app with Bilibili integration and Markdown support",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npx vite",
    "build": "npx tsc && npx vite build",
    "electron:dev": "npx vite --mode electron",
    "electron:build": "npx tsc && npx vite build --mode electron && npx electron-builder",
    "sync-android": "node scripts/sync-android-version.js && npx cap sync android",
    "version:patch": "npm version patch && node scripts/sync-android-version.js && git add android/app/build.gradle && git commit --amend --no-edit",
    "version:minor": "npm version minor && node scripts/sync-android-version.js && git add android/app/build.gradle && git commit --amend --no-edit"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "docx": "^8.5.0",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.383.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "uuid": "^9.0.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.videonote.app",
    "productName": "VideoNote",
    "copyright": "Copyright © 2026 VideoNote",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "node_modules/docx/**/*",
      "node_modules/file-saver/**/*"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VideoNote",
      "installerHeaderIcon": "build/icon.ico",
      "uninstallDisplayName": "VideoNote ${version}"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
